# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Gitlab Ci Local
.gitlab-ci-local

#Ignore claude
/.claude

# dependencies
/node_modules
/.npm
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env.local*
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# CI/CD artifacts
gl-codequality.json
gl-dependency-scanning-report.json
